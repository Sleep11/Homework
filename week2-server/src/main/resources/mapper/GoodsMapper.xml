<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bwie.mapper.GoodsMapper">
  <resultMap id="BaseResultMap" type="com.bwie.domain.Goods">
    <!--@mbg.generated-->
    <!--@Table t_goods-->
    <id column="id" jdbcType="INTEGER" property="id" />
    <result column="goods_no" jdbcType="VARCHAR" property="goodsNo" />
    <result column="goods_name" jdbcType="VARCHAR" property="goodsName" />
    <result column="goods_category" jdbcType="VARCHAR" property="goodsCategory" />
    <result column="stock" jdbcType="INTEGER" property="stock" />
    <result column="unit" jdbcType="VARCHAR" property="unit" />
    <result column="status" jdbcType="INTEGER" property="status" />
    <result column="create_date" jdbcType="DATE" property="createDate" />
    <result column="last_time" jdbcType="TIMESTAMP" property="lastTime" />
  </resultMap>
  <sql id="Base_Column_List">
    <!--@mbg.generated-->
    id, goods_no, goods_name, goods_category, stock, unit, `status`, create_date, last_time
  </sql>

  <select id="goodsVoList" resultType="com.bwie.domain.vo.GoodsVo">
    select g.*,d.dict_name from t_goods g  join t_dict d on g.status=d.dict_code
    <if test="goodsNo!=null  and goodsNo!='' ">
      and g.goods_no=#{goodsNo}
    </if>
    <if test="goodsName!=null  and goodsName!='' ">
      and instr(g.goods_name,#{goodsName})
    </if>
    <if test="start != null and start != '' ">
      and g.create_date>=#{start}
    </if>
    <if test="end != null and end != '' ">
      and g.create_date &lt;=#{end}
    </if>
  </select>

  <select id="pageList" resultType="com.bwie.domain.vo.GoodsVo">
    select g.*,d.dict_name from t_goods g  join t_dict d on g.status=d.dict_code
    <if test="queryDto.goodsNo!=null  and queryDto.goodsNo!='' ">
      and g.goods_no=#{queryDto.goodsNo}
    </if>
    <if test="queryDto.goodsName!=null  and queryDto.goodsName!='' ">
      and instr(g.goods_name,#{queryDto.goodsName})
    </if>
    <if test="queryDto.start != null and queryDto.start != '' ">
      and g.create_date>=#{queryDto.start}
    </if>
    <if test="queryDto.end != null and queryDto.end != '' ">
      and g.create_date &lt;=#{queryDto.end}
    </if>
  </select>

</mapper>